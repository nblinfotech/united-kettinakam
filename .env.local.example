# MongoDB connection string from MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/united-kettinakam?retryWrites=true&w=majority

# Admin secret key — choose any strong random string
ADMIN_SECRET=your-super-secret-admin-key-here

# SMTP settings for email notifications (optional — use Gmail, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ADMIN_EMAIL=admin@unitedkettinakam.com
